<Window x:Class="POSPOINT.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="POSPOINT - Multi-Location Retail ERP System" Height="600" Width="1000"
        WindowState="Maximized"
        Background="#F5F5F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Sidebar Navigation -->
        <StackPanel Grid.Column="0" Background="#2C3E50" VerticalAlignment="Stretch">
            <TextBlock Text="POSPOINT" Foreground="White" FontSize="18" FontWeight="Bold" Padding="15"/>
            <Separator Background="#34495E"/>
            
            <Button Content="Dashboard" Foreground="White" Background="Transparent" Padding="15,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
            <Button Content="POS" Foreground="White" Background="Transparent" Padding="15,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
            <Button Content="Inventory" Foreground="White" Background="Transparent" Padding="15,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
            <Button Content="Products" Foreground="White" Background="Transparent" Padding="15,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
            <Button Content="Barcodes" Foreground="White" Background="Transparent" Padding="15,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
            <Button Content="Stores" Foreground="White" Background="Transparent" Padding="15,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
            <Button Content="Reports" Foreground="White" Background="Transparent" Padding="15,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
            <Button Content="Settings" Foreground="White" Background="Transparent" Padding="15,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
        </StackPanel>
        
        <!-- Main Content Area -->
        <Grid Grid.Column="1" Background="White">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Welcome to POSPOINT" FontSize="32" FontWeight="Bold" Foreground="#2C3E50" TextAlignment="Center"/>
                <TextBlock Text="Multi-Location Retail ERP System" FontSize="16" Foreground="#7F8C8D" TextAlignment="Center" Margin="0,10,0,0"/>
                <TextBlock Text="Version 1.0" FontSize="12" Foreground="#95A5A6" TextAlignment="Center" Margin="0,20,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
